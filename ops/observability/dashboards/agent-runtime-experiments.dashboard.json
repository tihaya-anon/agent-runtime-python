        "wideLayout": true
      },
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"agent-runtime-python\",span_name=\"experiment.trial\"}[5m]) * 60)",
