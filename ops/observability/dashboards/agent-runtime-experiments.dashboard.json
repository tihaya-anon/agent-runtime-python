    {
      "datasource": {
        "type": "tempo",
        "uid": "tempo"
      },
      "description": "Use the returned trace IDs as the drilldown path into Tempo; filter logs in Grafana Explore by agent_run_id when needed.",
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "repeatDirection": "h",
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "filters": [],
          "limit": 50,
          "query": "{ resource.service.name = \"agent-runtime-python\" && span:name = \"experiment.trial\" && (span.\"metadata.experiment.study_id\" = \"$study_id\" || \"$study_id\" = \"\") && (span.\"metadata.experiment.trial_id\" = \"$trial_id\" || \"$trial_id\" = \"\") && (span.\"session.id\" = \"$agent_run_id\" || \"$agent_run_id\" = \"\") } | select(span:name, trace:id, span:duration, span:status, span.\"metadata.experiment.study_id\", span.\"metadata.experiment.trial_id\", span.\"metadata.experiment.target\", span.\"metadata.experiment.outcome\", span.\"session.id\", span.\"metadata.agent_run.outcome\")",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "spans"
        }
      ],
      "title": "Recent Trial Drilldown",
      "transformations": [],
      "transparent": false,
      "type": "table"
