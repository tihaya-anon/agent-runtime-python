      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "tempo"
          },
          "filters": [],
          "limit": 200,
          "query": "{ resource.service.name = \"agent-runtime-python\" && span:name = \"experiment.trial\" && (span.\"metadata.experiment.study_id\" = \"$study_id\" || \"$study_id\" = \"\") } | select(span:name, trace:id, span:duration, span:status, span.\"metadata.experiment.study_id\", span.\"metadata.experiment.trial_id\", span.\"metadata.experiment.target\", span.\"metadata.experiment.outcome\", span.\"session.id\", span.\"metadata.agent_run.outcome\")",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "spans"
        }
      ],
      "title": "Recent Experiment Trials",
      "transformations": [],
      "transparent": false,
      "type": "table"
    },
