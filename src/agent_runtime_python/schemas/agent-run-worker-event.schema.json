{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "providerUsage": {
      "type": "object",
      "properties": {
        "inputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0
        },
        "cachedInputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "cacheCreationInputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "reasoningOutputTokens": {
          "type": "integer",
          "minimum": 0
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "modelUsageBreakdown": {
      "type": "object",
      "properties": {
        "provider": {
          "type": "string"
        },
        "model": {
          "type": "string"
        },
        "graphId": {
          "type": "string"
        },
        "nodeName": {
          "type": "string"
        },
        "inputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "outputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "totalTokens": {
          "type": "integer",
          "minimum": 0
        },
        "cachedInputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "cacheCreationInputTokens": {
          "type": "integer",
          "minimum": 0
        },
        "reasoningOutputTokens": {
          "type": "integer",
          "minimum": 0
        }
      },
      "required": [
        "provider",
        "model"
      ],
      "additionalProperties": false
    }
  },
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "type": {
          "type": "string",
          "const": "run.started"
        },
        "agentRunId": {
          "type": "string"
        }
      },
      "required": [
        "version",
        "type",
        "agentRunId"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "type": {
          "type": "string",
          "const": "message.delta"
        },
        "text": {
          "type": "string"
        }
      },
      "required": [
        "version",
        "type",
        "text"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "type": {
          "type": "string",
          "const": "progress.update"
        },
        "scope": {
          "type": "string",
          "enum": [
            "run",
            "task"
          ]
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "started",
            "running",
            "completed",
            "failed",
            "cancelled"
          ]
        },
        "message": {
          "type": "string"
        }
      },
      "required": [
        "version",
        "type",
        "scope",
        "label"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "type": {
          "type": "string",
          "const": "usage.snapshot"
        },
        "usage": {
          "$ref": "#/$defs/providerUsage"
        },
        "modelUsage": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modelUsageBreakdown"
          },
          "minItems": 1
        }
      },
      "required": [
        "version",
        "type",
        "usage",
        "modelUsage"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "type": {
          "type": "string",
          "const": "run.completed"
        }
      },
      "required": [
        "version",
        "type"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "type": {
          "type": "string",
          "const": "run.failed"
        },
        "errorClassification": {
          "type": "string",
          "enum": [
            "validation",
            "provider",
            "tool",
            "timeout",
            "cancellation_failed",
            "internal"
          ]
        }
      },
      "required": [
        "version",
        "type",
        "errorClassification"
      ],
      "additionalProperties": false
    },
    {
      "type": "object",
      "properties": {
        "version": {
          "type": "number",
          "const": 1
        },
        "type": {
          "type": "string",
          "const": "run.cancelled"
        }
      },
      "required": [
        "version",
        "type"
      ],
      "additionalProperties": false
    }
  ]
}
